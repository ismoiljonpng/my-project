# ─────────────────────────────────────────────────────────────
# Аль-Аббос — переменные окружения
# Скопируйте этот файл в .env.local и подставьте реальные значения.
# .env.local в репозиторий НЕ коммитится (см. .gitignore).
# ─────────────────────────────────────────────────────────────

# Supabase — URL проекта и публичный (anon) ключ.
# Берутся в панели Supabase: Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Яндекс.Карты — ключ JS API (Кабинет разработчика Яндекса).
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-key

# Сервисный ключ Supabase — ТОЛЬКО для сервера, на фронт не выводить.
# Нужен лишь если серверу требуется обходить RLS (например, фоновые задачи).
# Раскомментируйте при необходимости:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
